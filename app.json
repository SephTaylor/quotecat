{
  "expo": {
    "name": "QuoteCat",
    "slug": "quotecat",
    "version": "1.2.9",
    "runtimeVersion": "1.2.9",
    "updates": {
      "url": "https://u.expo.dev/dc5517f1-c28a-4507-804b-406cee16ff3c"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quotecat",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://quotecat.ai"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/qc-splash-tsnt-2048-text.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#F97316"
        }
      ],
      "@sentry/react-native/expo",
      [
        "expo-camera",
        {
          "cameraPermission": "QuoteCat uses the camera to take photos of your company logo and to scan product barcodes for your pricebook.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "splash": {
      "image": "./assets/images/qc-splash-tsnt-2048-text.png",
      "resizeMode": "contain",
      "backgroundColor": "#F97316"
    },
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "ai.quotecat.app",
      "buildNumber": "214",
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "splash": {
        "image": "./assets/images/qc-splash-tsnt-2048-text.png",
        "resizeMode": "contain",
        "backgroundColor": "#F97316"
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1046717490623-r844gjtfe3oj3156rtrnqvr4gebl44js"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "QuoteCat uses Face ID or Touch ID to securely sign you in with just one tap.",
        "NSPhotoLibraryUsageDescription": "QuoteCat needs access to your photo library so you can add your company logo to quotes and invoices.",
        "NSCameraUsageDescription": "QuoteCat uses the camera to take photos of your company logo and to scan product barcodes for your pricebook.",
        "NSMicrophoneUsageDescription": "QuoteCat uses the microphone for the Quote Wizard voice input feature.",
        "NSSpeechRecognitionUsageDescription": "QuoteCat uses speech recognition in the Quote Wizard to help you create quotes by voice."
      }
    },
    "android": {
      "package": "ai.quotecat.app",
      "versionCode": 61,
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#F97316",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "forceDarkAllowed": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "quotecat.ai",
              "pathPrefix": "/auth"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.googleusercontent.apps.1046717490623-6ilrgd7ucbvepnabncajjp6t785e5huk"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "androidStatusBar": {
      "backgroundColor": "#ffffff"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dc5517f1-c28a-4507-804b-406cee16ff3c"
      }
    }
  }
}
